# Anthropic API key (server-side only, used by Vercel functions)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs API key (server-side; used to mint signed voice URLs)
ELEVENLABS_API_KEY=...

# ElevenLabs agent ID (client-side, embedded in build)
# IMPORTANT: use raw agent id only (e.g. agent_abc123), not full URL/branch query
ELEVENLABS_AGENT_ID=agent_...

# Admin passphrase for /admin results view
ADMIN_PASSPHRASE=your-passphrase-here

# Vercel KV / Upstash Redis integration (server-side persistence)
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# Optional: namespace keys when sharing one DB across environments
# Examples: development, preview, production
KV_KEY_PREFIX=development
